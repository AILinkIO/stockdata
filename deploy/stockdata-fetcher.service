[Unit]
Description=stockdata fetcher (Celery worker, prefork)
Requires=postgresql.service valkey.service
After=network.target postgresql.service valkey.service

[Service]
Type=exec
User=david
WorkingDirectory=/home/david/workspace/stockdata
ExecStart=/usr/bin/env uv run celery -A fetcher.app worker --loglevel=info
# Celery 优雅退出：等待在执行的任务完成（最长至 task_time_limit）
TimeoutStopSec=120
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
