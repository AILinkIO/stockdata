{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "StockData": {
    "FetchBase": "http://127.0.0.1:8090",
    "Sync": {
      "DrainIdleSeconds": 10,
      "MarketRefreshSeconds": 3600,
      "HaltBackoffSeconds": 120
    },
    "FetchHaltPollSeconds": 60,
    "FetchRestartCooldownSeconds": 600,
    "FetchWaitTimeout": 120,
    "FetchPollMs": 500
  }
}