[Unit]
Description=stockdata API (FastAPI/uvicorn)
Requires=postgresql.service valkey.service
After=network.target postgresql.service valkey.service

[Service]
Type=exec
User=david
WorkingDirectory=/home/david/workspace/stockdata/server
ExecStart=/usr/bin/env uv run uvicorn api.main:app --host 0.0.0.0 --port 8080
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
