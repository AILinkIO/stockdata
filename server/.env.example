# dotnet(mcp) 直连 PG 的连接串（Python fetch 不碰 PG，仅 mcp 用此项）
STOCKDATA_PG_DSN=postgresql+psycopg://stockdata:YOUR_PASSWORD@127.0.0.1:5432/stockdata

# baostock 抓取限流（防 IP 拉黑），<=0 关闭
STOCKDATA_FETCH_RATE_LIMIT_PER_MINUTE=60
STOCKDATA_RATE_LIMIT_BACKEND=redis                       # memory（进程内）/ redis（跨进程）
STOCKDATA_RATE_LIMIT_REDIS_URL=redis://127.0.0.1:6379/1  # 限流 Redis（独立 DB）

# fetch job 存储（异步 submit+poll 的状态/去重/结果），独立 DB 避免与限流冲突
STOCKDATA_FETCH_JOB_REDIS_URL=redis://127.0.0.1:6379/2

# baostock socket 超时（秒）
STOCKDATA_BAOSTOCK_SOCKET_TIMEOUT=30

# 抓取退避重试：base*2^n 指数增长封顶 max_backoff（30→60→120→180→180…），耗尽才标 failed
STOCKDATA_FETCH_MAX_RETRIES=8
STOCKDATA_FETCH_RETRY_BASE_SECONDS=30
STOCKDATA_FETCH_RETRY_MAX_BACKOFF_SECONDS=180

# watchdog 硬超时：单次 baostock 查询到点强制注入异常中断（兜底库内 recv 死循环）
STOCKDATA_FETCH_WATCHDOG_TIMEOUT_SECONDS=600   # 10 分钟

# 空闲自动登出：worker 闲置超过该秒数主动登出关 socket（下次查询重登录），<=0 关闭
STOCKDATA_FETCH_IDLE_LOGOUT_SECONDS=900   # 15 分钟

# 网络接收错误(10002007)熔断：默认按可重试(relogin 自愈)，连续达此次数才升级暂停待 /restart
STOCKDATA_FETCH_RECEIVE_ERROR_HALT_THRESHOLD=5
