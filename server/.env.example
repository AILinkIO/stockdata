STOCKDATA_PG_DSN=postgresql+psycopg://stockdata:28e3acd8a3ddfb44bacb79d3720e8060@127.0.0.1:5432/stockdata
STOCKDATA_BROKER_URL=redis://127.0.0.1:6379/2
STOCKDATA_RESULT_BACKEND=redis://127.0.0.1:6379/3

# 每分钟最多向数据源发起的查询次数（防 IP 拉黑），<=0 关闭限流
STOCKDATA_FETCH_RATE_LIMIT_PER_MINUTE=60

# 限流实现：memory（进程内）或 redis（跨进程安全）
STOCKDATA_RATE_LIMIT_BACKEND=memory
# 限流 Redis 地址，空则复用 broker_url；backend=redis 时建议用独立 DB 避免与 broker 冲突
# 示例：redis://127.0.0.1:6379/4
STOCKDATA_RATE_LIMIT_REDIS_URL=

# 抓取重试/退避：base*2^n 指数增长，封顶 max_backoff（默认 30→60→120→180→180…）
# 重试次数耗尽才标记 failed
STOCKDATA_FETCH_MAX_RETRIES=8
STOCKDATA_FETCH_RETRY_BASE_SECONDS=30
STOCKDATA_FETCH_RETRY_MAX_BACKOFF_SECONDS=180
