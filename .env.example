# PostgreSQL 连接串（物理机服务）
STOCKDATA_PG_DSN=postgresql://stockdata:YOUR_PASSWORD@127.0.0.1:5432/stockdata

# ── Web / API ──
#STOCKDATA_WEB_PORT=8050
#STOCKDATA_APP_BASE=http://127.0.0.1:8050   # CLI 客户端连接地址

# ── baostock 红线（默认值即生产值，一般不用改）──
#STOCKDATA_RATE_LIMIT_PER_MINUTE=90         # 限流：每分钟查询上限，<=0 关闭
#STOCKDATA_MIN_LOGIN_INTERVAL_SECONDS=300   # 任何两次 bs.login 间隔 ≥5 分钟（PG 持久化强制）
#STOCKDATA_BAOSTOCK_SOCKET_TIMEOUT=30
#STOCKDATA_RECEIVE_ERROR_HALT_THRESHOLD=5   # 连续 10002007 达此次数熔断
#STOCKDATA_IDLE_LOGOUT_SECONDS=900          # 空闲自动登出
#STOCKDATA_WATCHDOG_TIMEOUT_SECONDS=600     # 单次查询硬超时

# ── 抓取退避重试 ──
#STOCKDATA_MAX_RETRIES=8
#STOCKDATA_RETRY_BASE_SECONDS=30
#STOCKDATA_RETRY_MAX_BACKOFF_SECONDS=180

# ── 同步回填边界与节奏 ──
#STOCKDATA_MINUTE_BACKFILL_FLOOR=2023-01-01   # 分钟线最早回填日
#STOCKDATA_FINANCIAL_BACKFILL_FLOOR=2020-01-01 # 财报回填下限（全历史 ≈21 天连续同步，慎开）
#STOCKDATA_KLINE_SLICE_DAYS=3650
#STOCKDATA_MINUTE_SLICE_DAYS=180
#STOCKDATA_STALE_AFTER_HOURS=20               # 未结算数据重查间隔
#STOCKDATA_SNAPSHOT_REFRESH_DAYS=7            # 行业/指数成分/复权因子兜底重抓间隔
